# Scheduled Report Generator — Example Configuration

aws_region = "us-east-1"
aws_profile = "default"

project_name = "scheduled-report-generator"
environment  = "dev"

# Anthropic API key (required)
# Get from https://console.anthropic.com
anthropic_api_key = "sk-ant-..."

anthropic_model = "claude-sonnet-4-20250514"
max_tokens      = 2048

# SES configuration
# The sender email must be verified in AWS SES
ses_sender_email = "reports@example.com"

# Report recipients (at least one email required)
report_recipients = [
  "stakeholder1@example.com",
  "stakeholder2@example.com"
]

# EventBridge cron expression (UTC timezone)
# Format: cron(minute hour day month day-of-week year)
#
# Examples:
#   "0 9 * * *"         = Every day at 9:00 AM UTC
#   "0 9 * * 1"         = Every Monday at 9:00 AM UTC
#   "0 9 * * MON-FRI"   = Weekdays at 9:00 AM UTC
#   "0 8 1 * *"         = First day of month at 8:00 AM UTC
#   "0 9 * * 0,6"       = Weekends at 9:00 AM UTC
report_schedule_cron = "0 9 * * *"

# Report type: daily_summary, weekly_digest, or monthly_review
report_type = "daily_summary"

# Report timezone for display (IANA timezone names)
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
report_timezone = "America/New_York"

# Lambda configuration
lambda_memory = 512
lambda_timeout = 60

# CloudWatch retention for logs (days)
log_retention_days = 14

# DynamoDB billing mode: PAY_PER_REQUEST or PROVISIONED
dynamodb_billing_mode = "PAY_PER_REQUEST"
